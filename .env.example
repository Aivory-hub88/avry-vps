# =============================================================================
# Aivory VPS Panel - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the required values.
# Required variables are marked with [REQUIRED].
# =============================================================================

# ─── Core Settings (Required) ───────────────────────────────────────────────────

# [REQUIRED] HTTP port the panel listens on
PORT=3000

# [REQUIRED] JWT secret for authentication token validation
SUPABASE_JWT_SECRET=your-jwt-secret-here

# [REQUIRED] Docker daemon socket path or TCP address
DOCKER_HOST=/var/run/docker.sock

# [REQUIRED] Deployment environment: development, staging, production
ENVIRONMENT=production

# ─── Panel Access ────────────────────────────────────────────────────────────────

# Admin credentials for panel login
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# Subdomain where the panel is accessible via reverse proxy
PANEL_DOMAIN=panel.aivory.id

# Enable HTTPS redirect (set to true when TLS certificate is active)
TLS_ENABLED=false

# ─── Database ────────────────────────────────────────────────────────────────────

# SQLite database file path (inside the container) - for existing operational data
DB_PATH=/app/data/panel.db

# [REQUIRED] PostgreSQL connection string for monitoring data and project registry
# Points to the shared avry-postgres instance on the Docker network
DATABASE_URL=postgresql://aivory:your-password@avry-postgres:5432/aivory

# ─── Monitoring API ──────────────────────────────────────────────────────────────

# [REQUIRED] Shared secret token for authenticating external services (Admin Dashboard, project apps)
# Must be the same value configured in the Admin Dashboard's VPS_PANEL_API_TOKEN
VPS_PANEL_API_TOKEN=your-secure-api-token-here

# Maximum monitoring API requests per minute per client (default: 60)
# VPS_PANEL_RATE_LIMIT=60

# ─── CORS ────────────────────────────────────────────────────────────────────────

# Comma-separated list of allowed CORS origins (use * for all)
CORS_ORIGINS=*

# ─── Email Alerts (SMTP) ─────────────────────────────────────────────────────────

# SMTP server configuration for email alerts
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ─── Webhook Alerts ──────────────────────────────────────────────────────────────

# Webhook URL for alert delivery (Slack/Discord compatible)
ALERT_WEBHOOK_URL=

# ─── Backup Storage (S3-Compatible) ──────────────────────────────────────────────

# S3-compatible storage for remote backups
BACKUP_S3_ENDPOINT=
BACKUP_S3_BUCKET=
BACKUP_S3_ACCESS_KEY=
BACKUP_S3_SECRET_KEY=
